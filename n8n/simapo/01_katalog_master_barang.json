    {
      "parameters": { "httpMethod": "GET", "path": "simapo-admin-master-list", "responseMode": "responseNode", "options": {} },
      "type": "n8n-nodes-base.webhook", "typeVersion": 2, "position": [0, 300],
      "id": "wh-master-list", "name": "WH Master List", "webhookId": "simapo-admin-master-list"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT b.id, b.kodebarang, b.nama, b.satuan, b.spesifikasi, b.foto, b.stok_saat_ini, b.minimumstok, b.hargasatuan, b.kategoriid, k.nama AS nama_kategori, b.isactive, TO_CHAR(b.createdat,'YYYY-MM-DD') AS createdat FROM \"SIMAPO\".barang b LEFT JOIN \"SIMAPO\".kategori_barang k ON k.id = b.kategoriid ORDER BY b.isactive DESC, b.nama ASC;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres", "typeVersion": 2.6, "position": [240, 300],
      "id": "pg-master-list", "name": "PG Master List",
