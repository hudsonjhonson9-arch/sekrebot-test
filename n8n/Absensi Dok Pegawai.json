    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO \"public\".\"dokumen_pegawai\" (\n    \"nip\", \n    \"nama_dokumen\", \n    \"jenis\", \n    \"tanggal\", \n    \"instansi_id\", \n    \"link\", \n    \"file\", \n    \"tambah_oleh\"\n) VALUES (\n    '{{ ($json.nip).toString().replace(/'/g, "''") }}', \n    '{{ ($json.nama_dokumen).toString().replace(/'/g, "''") }}', \n    '{{ ($json.jenis).toString().replace(/'/g, "''") }}', \n    '{{ ($json.tanggal).toString().replace(/'/g, "''") }}', \n    'bapperida', \n    '{{ ($json.link).toString().replace(/'/g, "''") }}', \n    NULLIF('{{ ($json.file_base64).toString().replace(/'/g, "''") }}', ''), \n    '{{ ($json.tambah_oleh).toString().replace(/'/g, "''") }}'\n) RETURNING *;",
        "options": {
          "queryBatching": "independently"
        }
      },
