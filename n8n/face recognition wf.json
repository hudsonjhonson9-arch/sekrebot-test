    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\n\nconst user_id = String(body.user_id || '').trim();\nconst saved_at = body.saved_at || new Date().toISOString();\nconst face_model = body.face_model || 'faceapi';\n\n// 1. Validasi user_id\nif (!user_id) {\n  return [{\n    json: { error: true, statusCode: 400, message: 'user_id wajib diisi' }\n  }];\n}\n\n// 2. Mode RESET\nif (body._reset) {\n  return [{ \n    json: { user_id, histogram_str: '[]', foto_base64: '', saved_at: '', face_model: 'faceapi', error: false } \n  }];\n}\n\n// 3. Mode SIMPAN\nconst face_descriptor = body.face_descriptor; \nconst foto_base64 = String(body.foto_base64 || '').trim();\n\nif (!face_descriptor || !Array.isArray(face_descriptor)) {\n  return [{\n    json: { error: true, statusCode: 400, message: 'face_descriptor wajib diisi (Array)' }\n  }];\n}\n\n// 4. Berhasil Parse\nreturn [{\n  json: {\n    user_id: user_id,\n    histogram_str: JSON.stringify(face_descriptor),\n    face_model: face_model,\n    foto_base64: foto_base64,\n    saved_at: saved_at,\n    error: false\n  }\n}];"
      },
