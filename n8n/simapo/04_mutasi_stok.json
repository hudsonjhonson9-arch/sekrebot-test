    {
      "parameters": {
        "jsCode": "const b = $input.item.json.body || $input.item.json;\nconst nip = b.nip || $input.item.json.headers?.['x-nip'] || 'ADMIN';\nconst jumlah = parseInt(b.jumlah) || 0;\nconst masId = b.barangmasukid || null;\nconst kelId = b.barangkeluarid || null;\nconst delta = masId ? jumlah : -jumlah;\nconst barangid = masId || kelId;\n\nreturn [{ json: {\n  barangmasukid: masId,\n  barangkeluarid: kelId,\n  barangid: barangid,\n  createdbyid: nip,\n  jumlah: jumlah,\n  delta: delta,\n  keterangan: b.keterangan || '',\n  tanggal: new Date().toISOString(),\n  instansi_id: b.instansi_id || $input.item.json.query?.instansi_id || 'bapperida'\n} }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
