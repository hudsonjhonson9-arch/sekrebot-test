    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO \"SIMAPO\".mutasi_barang (id, barangmasukid, barangkeluarid, createdbyid, jumlah, keterangan, tanggal, instansi_id) VALUES (gen_random_uuid(), {{ ($json.barangmasukid ? \"'\" + $json.barangmasukid + \"'\" : 'NULL').toString().replace(/'/g, \"''\") }}, {{ ($json.barangkeluarid ? \"'\" + $json.barangkeluarid + \"'\" : 'NULL').toString().replace(/'/g, \"''\") }}, '{{ ($json.createdbyid).toString().replace(/'/g, \"''\") }}', {{ ($json.jumlah).toString().replace(/'/g, \"''\") }}, '{{ ($json.keterangan).toString().replace(/'/g, \"''\") }}', '{{ ($json.tanggal).toString().replace(/'/g, \"''\") }}', '{{ ($json.instansi_id || \"bapperida\").toString().replace(/'/g, \"''\") }}'); UPDATE \"SIMAPO\".barang SET stok_saat_ini = GREATEST(0, stok_saat_ini + ({{ ($json.delta).toString().replace(/'/g, \"''\") }})), updatedat = NOW() WHERE id = '{{ ($json.barangid).toString().replace(/'/g, \"''\") }}' RETURNING id, stok_saat_ini;",
        "options": {}
