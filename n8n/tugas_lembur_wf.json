    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  l.\"NIP\" as nip, \n  l.\"Nama\" as nama, \n  l.\"Tanggal\" as tanggal, \n  MIN(CASE WHEN UPPER(l.\"Jenis Absen\") LIKE '%MASUK%' THEN l.\"Jam\" END) as jam_masuk, \n  MAX(CASE WHEN UPPER(l.\"Jenis Absen\") LIKE '%PULANG%' THEN l.\"Jam\" END) as jam_pulang, \n  MAX(l.\"Ket\") as status_absen,\n  MAX(CAST(p.id AS TEXT)) as is_tugas,\n  MAX(p.keterangan) as tugas_detail,\n  MAX(CASE WHEN UPPER(l.\"Jenis Absen\") IN ('SAKIT','TUGAS','IZIN','CUTI','TUBEL') THEN UPPER(l.\"Jenis Absen\") END) as keterangan_status\nFROM \"Log_Absen\" l\nLEFT JOIN penugasan p ON l.\"NIP\" = p.nip AND l.\"Tanggal\"::text = p.tanggal::text\nWHERE l.\"NIP\" IN ({{ (($json.query.nips || $json.query.nip || \"\").toString().split(',').map(x => \"'\" + x.trim() + \"'\").join(',')).toString().replace(/'/g, "''") }})\nAND l.\"Tanggal\" BETWEEN '{{ ($json.query.dari).toString().replace(/'/g, "''") }}' AND '{{ ($json.query.sampai).toString().replace(/'/g, "''") }}'\nGROUP BY l.\"NIP\", l.\"Nama\", l.\"Tanggal\"\nORDER BY l.\"Tanggal\" ASC, l.\"Nama\" ASC;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        1600,
        528
      ],
