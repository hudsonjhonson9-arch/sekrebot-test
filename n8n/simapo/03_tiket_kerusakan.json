    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO \"SIMAPO\".tiket_kerusakan (id, nomortiket, userid, judul, deskripsi, lokasi, status, createdat, updatedat, instansi_id) VALUES (gen_random_uuid(), '{{ ($json.nomortiket).toString().replace(/'/g, \"''\") }}', '{{ ($json.userid).toString().replace(/'/g, \"''\") }}', '{{ ($json.judul).toString().replace(/'/g, \"''\") }}', '{{ ($json.deskripsi).toString().replace(/'/g, \"''\") }}', '{{ ($json.lokasi).toString().replace(/'/g, \"''\") }}', '{{ ($json.status).toString().replace(/'/g, \"''\") }}', NOW(), NOW(), '{{ ($json.instansi_id || \"bapperida\").toString().replace(/'/g, \"''\") }}') RETURNING id, status;",
        "options": {}
