    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json);\n\nif (rows.length === 0 || Object.keys(rows[0]).length === 0) {\n  return [{ json: { ok: true, data: [], count: 0 } }];\n}\n\nconst docs = rows.map(r => ({\n  // Menggunakan nama_dokumen sebagai ID sementara karena kolom ID fisik belum ada\n  id:           r.nama_dokumen || '', \n  nip:          r.nip || '',\n  nama_dokumen: r.nama_dokumen || '—',\n  jenis:        (r.jenis || 'DOKUMEN').toUpperCase(),\n  link:         (r.link === '-' ? '' : r.link) || '',\n  tanggal:      r.tanggal || '',\n  tambah_oleh:  r.tambah_oleh || ''\n}));\n\nreturn [{ json: { ok: true, data: docs, count: docs.length } }];"
      },
