    {
      "parameters": {
        "operation": "executeQuery",
        "query": " {{ (() => {\n  const q = $json.query || {};\n  const instansi = (q.instansi_id || 'bapperida').replace(/'/g, \"''\");\n  const limit = parseInt(q.limit) || 100;\n  \n  if (q.created_by_nip) {\n    return \\`SELECT * FROM penugasan WHERE created_by_nip = '\\${q.created_by_nip.replace(/'/g, \"''\")}' AND instansi_id = '\\${instansi}' ORDER BY tanggal DESC LIMIT \\${limit};\\`;\n  }\n  if (q.nip === 'all' || !q.nip) {\n    return \\`SELECT * FROM penugasan WHERE instansi_id = '\\${instansi}' ORDER BY tanggal DESC LIMIT \\${limit};\\`;\n  }\n  return \\`SELECT * FROM penugasan WHERE nip = '\\${q.nip.replace(/'/g, \"''\")}' AND instansi_id = '\\${instansi}' ORDER BY tanggal DESC LIMIT \\${limit};\\`;\n})() }}",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        1600,
        336
      ],
      "id": "29965dff-37ad-4382-a1dd-f2586112d738",
      "name": "Postgres: Select Penugasan",
      "credentials": {
        "postgres": {
          "id": "vYOiyrTftLtD3zzd",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": " {{ (() => {\n  const b = $json.body || {};\n  const q = $json.query || {};\n  const instansi = (b.instansi_id || q.instansi_id || 'bapperida').replace(/'/g, \"''\");\n  \n  if (b.id) {\n    return \\`UPDATE penugasan SET status = '\\${(b.status || '').replace(/'/g, \"''\")}', bukti = '\\${(b.bukti || '').replace(/'/g, \"''\")}', lat_pengerjaan = \\${b.actual_lat || 0}, lon_pengerjaan = \\${b.actual_lon || 0}, instansi_id = '\\${instansi}' WHERE id = '\\${b.id.replace(/'/g, \"''\")}' RETURNING *;\\`;\n  } else {\n    return \\`INSERT INTO penugasan (user_id, nama, nip, tanggal, lat, lon, keterangan, created_by, created_by_nip, radius, instansi_id) VALUES ('\\${(b.user_id || '').replace(/'/g, \"''\")}', '\\${(b.nama || '').replace(/'/g, \"''\")}', '\\${(b.nip || '').replace(/'/g, \"''\")}', '\\${(b.tanggal || '').replace(/'/g, \"''\")}', \\${b.lat || 0}, \\${b.lon || 0}, '\\${(b.keterangan || '').replace(/'/g, \"''\")}', '\\${(b.created_by || '').replace(/'/g, \"''\")}', '\\${(b.created_by_nip || '').replace(/'/g, \"''\")}', \\${b.radius || 100}, '\\${instansi}') RETURNING *;\\`;\n  }\n})() }}",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        1600,
        0
      ],
      "id": "971cc81f-21b5-4727-ad76-cbff0ee5afb5",
      "name": "Postgres: Save/Update",
