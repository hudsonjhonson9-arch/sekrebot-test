    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH p_old AS (\n  SELECT id, unitasetid, status FROM \"SIMAPO\".peminjaman WHERE id = '{{ ($json.body.id).toString().replace(/'/g, \"''\") }}'\n),\nbarang_resolve AS (\n  SELECT COALESCE(b.id, b2.id) AS barang_id\n  FROM \"SIMAPO\".peminjaman p\n  LEFT JOIN \"SIMAPO\".barang b ON b.id = p.unitasetid\n  LEFT JOIN \"SIMAPO\".unit_aset ua ON ua.id = p.unitasetid\n  LEFT JOIN \"SIMAPO\".barang b2 ON b2.id = ua.barangid\n  WHERE p.id = '{{ ($json.body.id).toString().replace(/'/g, \"''\") }}'\n),\np_upd AS (\n  UPDATE \"SIMAPO\".peminjaman \n  SET status = '{{ ($json.body.status).toString().replace(/'/g, \"''\") }}', updatedat = NOW() \n  WHERE id = '{{ ($json.body.id).toString().replace(/'/g, \"''\") }}' \n  RETURNING id, status, unitasetid\n),\nb_upd AS (\n  UPDATE \"SIMAPO\".barang b\n  SET stok_saat_ini = b.stok_saat_ini + \n      CASE \n          WHEN p_old.status = 'MENUNGGU' AND p_upd.status IN ('DIPINJAM', 'SELESAI') THEN -1\n          WHEN (p_old.status = 'DIPINJAM' OR p_old.status = 'MENUNGGU') AND p_upd.status IN ('DIKEMBALIKAN', 'KEMBALI') THEN 1\n          ELSE 0\n      END\n  FROM p_old, p_upd, barang_resolve\n  WHERE b.id = barang_resolve.barang_id\n)\nSELECT id, status FROM p_upd;",
        "options": {}
      },
