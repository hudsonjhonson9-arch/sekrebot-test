    {
      "parameters": { "httpMethod": "POST", "path": "simapo-admin-master-save", "responseMode": "responseNode", "options": {} },
      "type": "n8n-nodes-base.webhook", "typeVersion": 2, "position": [0, 600],
      "id": "wh-master-save", "name": "WH Master Save", "webhookId": "simapo-admin-master-save"
    },
    {
      "parameters": {
        "jsCode": "const b = $input.item.json.body || $input.item.json;\nif (!b.nama) throw new Error('Nama barang wajib diisi');\nif (!b.kodebarang) throw new Error('Kode barang wajib diisi');\nreturn [{ json: {\n  id: b.id || null,\n  nama: b.nama,\n  kodebarang: b.kodebarang,\n  satuan: b.satuan || 'Unit',\n  spesifikasi: b.spesifikasi || '',\n  foto: b.foto || '',\n  stok_saat_ini: parseInt(b.stok_saat_ini) || 0,\n  hargasatuan: parseFloat(b.hargasatuan) || 0,\n  kategoriid: b.kategoriid || null\n} }];"
      },
      "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [240, 600],
      "id": "code-master-save", "name": "Validate Barang"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO \"SIMAPO\".barang (id, kodebarang, nama, satuan, spesifikasi, foto, stok_saat_ini, minimumstok, hargasatuan, kategoriid, isactive, createdat, updatedat)\nVALUES (COALESCE('{{ $json.id }}'::uuid, gen_random_uuid()), '{{ $json.kodebarang }}', '{{ $json.nama }}', '{{ $json.satuan }}', '{{ $json.spesifikasi }}', '{{ $json.foto }}', {{ $json.stok_saat_ini }}, 0, {{ $json.hargasatuan }}, {{ $json.kategoriid ? \"'\" + $json.kategoriid + \"'\" : 'NULL' }}, true, NOW(), NOW())\nON CONFLICT (id) DO UPDATE SET nama=EXCLUDED.nama, kodebarang=EXCLUDED.kodebarang, satuan=EXCLUDED.satuan, spesifikasi=EXCLUDED.spesifikasi, foto=EXCLUDED.foto, hargasatuan=EXCLUDED.hargasatuan, kategoriid=EXCLUDED.kategoriid, updatedat=NOW()\nRETURNING id, nama;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres", "typeVersion": 2.6, "position": [480, 600],
      "id": "pg-master-save", "name": "PG UPSERT Barang",
      "credentials": { "postgres": { "id": "vYOiyrTftLtD3zzd", "name": "Postgres account" } }
    },
    {
      "parameters": { "respondWith": "json", "responseBody": "={{ { \"success\": true, \"message\": \"Data aset berhasil disimpan\", \"id\": $json.id } }}", "options": {} },
      "type": "n8n-nodes-base.respondToWebhook", "typeVersion": 1.1, "position": [720, 600],
      "id": "res-master-save", "name": "Res Master Save"
    },

    {
      "parameters": { "httpMethod": "POST", "path": "simapo-admin-master-delete", "responseMode": "responseNode", "options": {} },
      "type": "n8n-nodes-base.webhook", "typeVersion": 2, "position": [0, 900],
      "id": "wh-master-del", "name": "WH Master Delete", "webhookId": "simapo-admin-master-delete"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE \"SIMAPO\".barang SET isactive = false, updatedat = NOW() WHERE id = '{{ ($input.item.json.body || $input.item.json).id }}' RETURNING id, nama;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres", "typeVersion": 2.6, "position": [240, 900],
      "id": "pg-master-del", "name": "PG Soft Delete",
      "credentials": { "postgres": { "id": "vYOiyrTftLtD3zzd", "name": "Postgres account" } }
    },
    {
      "parameters": { "respondWith": "json", "responseBody": "={{ { \"success\": true, \"message\": \"Aset dinonaktifkan\", \"id\": $json.id } }}", "options": {} },
      "type": "n8n-nodes-base.respondToWebhook", "typeVersion": 1.1, "position": [480, 900],
      "id": "res-master-del", "name": "Res Master Delete"
    }
  ],
