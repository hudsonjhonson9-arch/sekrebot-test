{
  "name": "SIMAPO - Peminjaman (User & Admin)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "simapo-pinjam",
        "responseMode": "responseNode",
        "options": {}
      },
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        0,
        0
      ],
      "id": "wh-pinjam-create",
      "name": "WH Ajukan Pinjam",
      "webhookId": "simapo-pinjam"
    },
    {
      "parameters": {
        "jsCode": "const b = $input.item.json.body || $input.item.json;\nconst q = $input.item.json.query || {};\nconst nip = b.nip || $input.item.json.headers?.['x-nip'] || '';\nif (!nip) throw new Error('NIP tidak ditemukan');\nif (!b.unitasetid) throw new Error('Barang belum dipilih');\nif (!b.tujuanpeminjaman) throw new Error('Tujuan kosong');\nreturn [{ json: { \n  userid: nip, \n  unitasetid: b.unitasetid, \n  tujuanpeminjaman: b.tujuanpeminjaman, \n  tanggalmulai: b.tanggalmulai, \n  tanggalselesai: b.tanggalselesai, \n  nomorpeminjaman: 'PMJ-' + Date.now(),\n  instansi_id: b.instansi_id || q.instansi_id || 'bapperida'\n} }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        240,
        0
      ],
      "id": "code-pinjam-create",
      "name": "Validate Pinjam"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO \"SIMAPO\".peminjaman (id, nomorpeminjaman, userid, unitasetid, tujuanpeminjaman, tanggalmulai, tanggalselesai, status, createdat, updatedat, instansi_id) VALUES (gen_random_uuid(), '{{ ($json.nomorpeminjaman).toString().replace(/'/g, "''") }}', '{{ ($json.userid).toString().replace(/'/g, "''") }}', '{{ ($json.unitasetid).toString().replace(/'/g, "''") }}', '{{ ($json.tujuanpeminjaman).toString().replace(/'/g, "''") }}', '{{ ($json.tanggalmulai).toString().replace(/'/g, "''") }}', '{{ ($json.tanggalselesai).toString().replace(/'/g, "''") }}', 'MENUNGGU', NOW(), NOW(), '{{ ($json.instansi_id || \"bapperida\").toString().replace(/'/g, "''") }}') RETURNING id, status;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        480,
        0
      ],
      "id": "pg-pinjam-create",
      "name": "PG Insert Pinjaman",
      "credentials": {
        "postgres": {
          "id": "vYOiyrTftLtD3zzd",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { \"success\": true, \"message\": \"Pengajuan berhasil\", \"id\": $json.id } }}",
        "options": {}
      },
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        720,
        0
      ],
      "id": "res-pinjam-create",
      "name": "Res Ajukan Pinjam"
    },
    {
      "parameters": {
        "httpMethod": "GET",
        "path": "simapo-pinjam-list",
        "responseMode": "responseNode",
        "options": {}
      },
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        0,
        300
      ],
      "id": "wh-pinjam-list",
      "name": "WH Riwayat Pinjam",
      "webhookId": "simapo-pinjam-list"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT p.id, b.nama AS nama_barang, b.kodebarang, p.tujuanpeminjaman, TO_CHAR(p.tanggalmulai,'YYYY-MM-DD') as tanggalmulai, TO_CHAR(p.tanggalselesai,'YYYY-MM-DD') as tanggalselesai, p.status, TO_CHAR(p.createdat,'YYYY-MM-DD') AS createdat FROM \"SIMAPO\".peminjaman p JOIN \"SIMAPO\".barang b ON b.id = p.unitasetid WHERE p.userid = '{{ ($json.query.nip).toString().replace(/'/g, "''") }}' ORDER BY p.createdat DESC LIMIT 30;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        240,
        300
      ],
      "id": "pg-pinjam-list",
      "name": "PG Riwayat Pinjam",
      "credentials": {
        "postgres": {
          "id": "vYOiyrTftLtD3zzd",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { data: $input.all().map(i => i.json) } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
