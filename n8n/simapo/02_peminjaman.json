    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT COALESCE(json_agg(t.*), '[]'::json) as items FROM (\nSELECT p.id, COALESCE(b.nama, b2.nama) AS nama_barang, COALESCE(b.kodebarang, ua.nomorinventaris) AS kodebarang, p.tujuanpeminjaman, TO_CHAR(p.tanggalmulai,'YYYY-MM-DD') as tanggalmulai, TO_CHAR(p.tanggalselesai,'YYYY-MM-DD') as tanggalselesai, p.status, TO_CHAR(p.createdat,'YYYY-MM-DD') AS createdat FROM \"SIMAPO\".peminjaman p LEFT JOIN \"SIMAPO\".barang b ON b.id = p.unitasetid LEFT JOIN \"SIMAPO\".unit_aset ua ON ua.id = p.unitasetid LEFT JOIN \"SIMAPO\".barang b2 ON b2.id = ua.barangid WHERE p.userid = '{{ ($json.query.nip).toString().replace(/'/g, \"''\") }}' ORDER BY p.createdat DESC LIMIT 30\n) t;",
