    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json || {};\nconst userId = String(body.user_id || '').trim();\nconst nama = String(body.nama_dokumen || body.nama || '').trim();\nconst jenis = (body.jenis || body.kategori || 'DOKUMEN').toUpperCase();\n\n// Mengatur nilai default jika link tidak diinput\nlet link = body.link || body.webViewLink || '';\nif (!link) {\n    link = '-'; \n}\n\nconst mode = body.mode || 'link';\nconst file_base64 = body.file_base64 || null;\nconst file_name = body.file_name || null;\nconst mime_type = body.mime_type || 'application/octet-stream';\nconst tanggal = new Date().toISOString().slice(0, 10);\nconst tambah_oleh = String(body.tambah_oleh || body.added_by || userId);\n\n// Validasi\nif (!userId) return [{json:{error:true,message:'user_id wajib diisi'}}];\nif (!nama)   return [{json:{error:true,message:'nama_dokumen wajib diisi'}}];\nif (mode === 'upload' && !file_base64) return [{json:{error:true,message:'file_base64 wajib diisi untuk mode upload'}}];\n\nreturn [{\n    json: {\n        user_id: Number(userId) || userId,\n        nama_dokumen: nama,\n        jenis: jenis,\n        link: link,\n        file_base64: file_base64,\n        file_name: file_name,\n        mime_type: mime_type,\n        tanggal: tanggal,\n        tambah_oleh: tambah_oleh,\n        mode: mode,\n        error: false\n    }\n}];"
      },
