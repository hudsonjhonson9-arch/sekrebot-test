      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT k.id, k.nama, k.deskripsi, COUNT(b.id) AS jumlah_aset FROM \"SIMAPO\".kategori_barang k LEFT JOIN \"SIMAPO\".barang b ON b.kategoriid = k.id AND b.isactive = true AND b.instansi_id = '{{ ($json.query.instansi_id || ''bapperida'').toString().replace(/'/g, '''') }}' WHERE k.isactive = true AND k.instansi_id = '{{ ($json.query.instansi_id || ''bapperida'').toString().replace(/'/g, '''') }}' GROUP BY k.id, k.nama, k.deskripsi ORDER BY k.nama ASC;",
        "options": {}
