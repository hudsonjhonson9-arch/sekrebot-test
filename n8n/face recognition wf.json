    {
      "parameters": {
        "jsCode": "const row     = $input.first().json;\nconst histStr = String(row.face_histogram || '').trim();\nconst savedAt = row.face_saved_at || null;\nconst dataUrl = String(row.face_photo || '').trim() || null;\nconst face_model = row.face_model || null;\n\nif (!histStr || histStr === '[]') {\n  return [{ json: { ok: false, message: 'Belum ada data wajah', histogram: null, face_descriptor: null, descriptor: null, dataUrl: null } }];\n}\n\ntry {\n  const histogram = JSON.parse(histStr);\n  // Return all aliases so frontend can find descriptor regardless of field name\n  return [{ json: { \n    ok: true, \n    histogram,\n    face_descriptor: histogram,\n    descriptor: histogram,\n    face_model: face_model || (histogram.length >= 512 ? 'human' : 'faceapi'),\n    saved_at: savedAt,\n    savedAt: savedAt,\n    dataUrl\n  } }];\n} catch(_) {\n  return [{ json: { ok: false, message: 'Data histogram tidak valid', histogram: null, face_descriptor: null, descriptor: null, dataUrl: null } }];\n}"
      },
